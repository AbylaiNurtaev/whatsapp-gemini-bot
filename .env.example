PORT=3000
HTTP_TIMEOUT_MS=20000

WAPPI_API_TOKEN=your_wappi_api_token
WAPPI_PROFILE_ID=your_wappi_profile_id
WAPPI_BASE_URL=https://wappi.pro

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash

# Optional. If set, requests to /webhook must include this value in one of:
# Authorization, Webhook, X-Webhook-Auth, X-Wappi-Auth, X-Webhook-Secret.
WEBHOOK_AUTH=

# Optional. Used by `npm run setup:webhook`, for example:
# PUBLIC_BASE_URL=https://your-app.up.railway.app
PUBLIC_BASE_URL=

# Tone/persona for the WhatsApp assistant.
BOT_SYSTEM_PROMPT=Ты дружелюбный WhatsApp-ассистент компании. Отвечай кратко, понятно и по делу на языке пользователя. Если не хватает данных, задай один уточняющий вопрос.
